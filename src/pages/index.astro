---
import Layout from '../layouts/Layout.astro';

const phoneDisplay = '1 (619) 349-9996';
const phoneHref = 'tel:+16193499996';
const address = '9540 Waples St Suite D, San Diego, CA 92121';
const heroVideo =
	'https://video.wixstatic.com/video/322fab_980552a6502e453d958f8083a307e481/1080p/mp4/file.mp4';
const treatmentVideo =
	'https://video.wixstatic.com/video/11062b_3d68351cded1425a83c0d418196c02ba/1080p/mp4/file.mp4';
const calmVideo =
	'https://video.wixstatic.com/video/11062b_cf4444776baf4b40a69972b4abe23417/720p/mp4/file.mp4';
const brandImage =
	'https://static.wixstatic.com/media/322fab_ee77a6b814ee4d71a73bbb0831313f8e~mv2.png';

const navItems = [
	{ label: 'About', href: '#about' },
	{ label: 'Treatments', href: '#treatments' },
	{ label: 'Hours', href: '#hours' },
	{ label: 'Contact', href: '#contact' },
];

const treatments = [
	{
		title: 'Deep Tissue Massage',
		price: '$80 per hour / $60 per half hour',
		text: 'Focused bodywork for muscle tension, deep stress, and areas that need extra attention.',
	},
	{
		title: 'Pain Relief Massage',
		price: 'Call for current availability',
		text: 'Therapeutic sessions shaped around discomfort, circulation, and recovery goals.',
	},
	{
		title: 'Hot Stone Massage',
		price: 'Call for current availability',
		text: 'Warm stone therapy designed to soften tight muscles and encourage full-body relaxation.',
	},
	{
		title: 'Cupping Therapy',
		price: '$40 per half hour',
		text: 'Targeted cupping support for circulation, mobility, and post-treatment ease.',
	},
];

const experienceCards = [
	{
		title: 'Skilled Therapists',
		text: 'Every session begins with a conversation about pressure, areas of focus, and wellness goals.',
	},
	{
		title: 'Personalized Techniques',
		text: 'Choose focused deep tissue work, gentle relaxation, hot stone therapy, or reflexology-inspired care.',
	},
	{
		title: 'Restful Setting',
		text: 'A quiet San Diego spa environment for stepping away from daily stress and returning refreshed.',
	},
];
---

<Layout>
	<header class="site-header">
		<a class="brand" href="#top" aria-label="Waples SPA home">
			<span>Waples</span>
			<small>SPA</small>
		</a>
		<nav class="main-nav" aria-label="Primary navigation">
			{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
		</nav>
		<a class="header-cta" href={phoneHref}>Book Now</a>
	</header>

	<main id="top">
		<section class="hero" aria-label="Waples SPA welcome">
			<video class="hero-media" autoplay muted loop playsinline src={heroVideo}></video>
			<div class="hero-overlay"></div>
			<div class="hero-content">
				<p class="eyebrow">Relaxing massage and wellness in San Diego</p>
				<h1>Waples SPA</h1>
				<p>
					A calm massage destination for deep relaxation, focused therapeutic care, and
					everyday renewal.
				</p>
				<div class="button-row">
					<a class="button primary" href={phoneHref}>Reserve by Phone</a>
					<a class="button ghost" href="#treatments">View Treatments</a>
				</div>
			</div>
		</section>

		<section class="intro" id="about">
			<div class="intro-copy">
				<p class="eyebrow">Welcome to Waples SPA</p>
				<h2>Your San Diego destination for relaxation and wellness.</h2>
			</div>
			<div class="intro-details">
				<p>
					Located at {address}, Waples SPA offers a tranquil place to unwind, recharge,
					and receive massage services from skilled therapists.
				</p>
				<p>
					Whether you want to release muscle tension, improve circulation, or simply take
					a restorative pause, each visit is tailored around your comfort and needs.
				</p>
				<a class="text-link" href={phoneHref}>Call {phoneDisplay}</a>
			</div>
		</section>

		<section class="text-image text-image-right">
			<div class="panel panel-sage">
				<p class="eyebrow">Therapeutic Massage</p>
				<h2>Focused techniques, delivered with a calm touch.</h2>
				<p>
					The spa offers deep tissue massage, pain relief massage, hot stone massage,
					foot reflexology, cupping therapy, and classic full-body relaxation.
				</p>
				<a class="button dark" href="#treatments">Explore Services</a>
			</div>
			<div class="media-card">
				<video autoplay muted loop playsinline src={treatmentVideo}></video>
			</div>
		</section>

		<section class="text-image text-image-left">
			<div class="media-card framed">
				<video autoplay muted loop playsinline src={calmVideo}></video>
			</div>
			<div class="panel panel-linen">
				<p class="eyebrow">Personalized Care</p>
				<h2>Each appointment begins with what your body needs today.</h2>
				<p>
					Before every session, therapists discuss pressure preferences, health concerns,
					and areas that need special attention so the experience feels restorative and
					complete.
				</p>
				<a class="button outline" href={phoneHref}>Plan a Visit</a>
			</div>
		</section>

		<section class="featured" id="treatments">
			<div class="featured-header">
				<p class="eyebrow">Massage Services</p>
				<h2>Restorative treatments for tension, circulation, and calm.</h2>
				<p>
					Choose a service that matches your pace, from targeted deep tissue support to a
					soothing hot stone escape.
				</p>
			</div>
			<div class="treatment-grid">
				{
					treatments.map((treatment) => (
						<article class="treatment-card">
							<div>
								<p class="card-kicker">{treatment.price}</p>
								<h3>{treatment.title}</h3>
								<p>{treatment.text}</p>
							</div>
							<a href={phoneHref}>Book treatment</a>
						</article>
					))
				}
			</div>
		</section>

		<section class="experience">
			<div class="experience-image" style={`background-image: url(${brandImage});`}></div>
			<div class="experience-content">
				<p class="eyebrow">The Experience</p>
				<h2>Relaxation is the service and the promise.</h2>
				<div class="experience-list">
					{
						experienceCards.map((card) => (
							<article>
								<h3>{card.title}</h3>
								<p>{card.text}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="amenities" id="hours">
			<div class="amenities-header">
				<p class="eyebrow">Visit Waples SPA</p>
				<h2>Open daily for appointments.</h2>
			</div>
			<div class="amenities-grid">
				<div>
					<h3>Open Hours</h3>
					<p>Mon-Sun: 09:30 AM-09:00 PM</p>
				</div>
				<div>
					<h3>Reservations</h3>
					<p><a href={phoneHref}>{phoneDisplay}</a></p>
				</div>
				<div>
					<h3>Address</h3>
					<p>{address}</p>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer" id="contact">
		<div>
			<p class="footer-brand">Waples SPA</p>
			<p>Relaxing Massage & Wellness in San Diego</p>
		</div>
		<div>
			<a href={phoneHref}>{phoneDisplay}</a>
			<span>{address}</span>
		</div>
	</footer>
</Layout>

<style>
	.site-header {
		position: fixed;
		z-index: 20;
		top: 0;
		left: 0;
		right: 0;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 2rem;
		padding: 1.25rem clamp(1rem, 4vw, 4rem);
		background: rgba(255, 250, 244, 0.9);
		backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(47, 46, 51, 0.12);
	}

	.brand {
		display: inline-flex;
		align-items: baseline;
		gap: 0.4rem;
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 2vw, 2.2rem);
		text-decoration: none;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.brand small {
		font-family: var(--font-body);
		font-size: 0.8rem;
		letter-spacing: 0.32em;
	}

	.main-nav {
		display: flex;
		align-items: center;
		gap: clamp(1rem, 3vw, 2.4rem);
		font-size: 0.8rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.main-nav a,
	.header-cta,
	.text-link,
	.treatment-card a,
	.site-footer a {
		text-decoration: none;
	}

	.header-cta {
		justify-self: end;
		padding: 0.8rem 1.4rem;
		border: 1px solid currentColor;
		border-radius: 999px;
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.hero {
		position: relative;
		min-height: 100vh;
		display: grid;
		place-items: end start;
		overflow: hidden;
		padding: 9rem clamp(1.25rem, 6vw, 6rem) 5rem;
		color: #fffaf4;
	}

	.hero-media,
	.hero-overlay {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.hero-media {
		object-fit: cover;
	}

	.hero-overlay {
		background:
			linear-gradient(90deg, rgba(22, 26, 21, 0.72), rgba(22, 26, 21, 0.22)),
			linear-gradient(0deg, rgba(22, 26, 21, 0.5), transparent 50%);
	}

	.hero-content {
		position: relative;
		max-width: 720px;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.75rem;
		letter-spacing: 0.22em;
		line-height: 1.6;
		text-transform: uppercase;
		color: var(--color-olive);
	}

	.hero .eyebrow {
		color: var(--color-linen);
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1,
	h2 {
		font-family: var(--font-display);
		font-weight: 400;
		line-height: 0.95;
		letter-spacing: -0.04em;
	}

	h1 {
		margin-bottom: 1.5rem;
		font-size: clamp(5rem, 15vw, 13rem);
	}

	h2 {
		margin-bottom: 1.4rem;
		font-size: clamp(2.8rem, 7vw, 6.8rem);
	}

	h3 {
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 2vw, 2.25rem);
		font-weight: 400;
	}

	p {
		color: var(--color-muted);
		font-size: clamp(1rem, 1.25vw, 1.15rem);
		line-height: 1.75;
	}

	.hero p {
		max-width: 560px;
		color: rgba(255, 250, 244, 0.86);
	}

	.button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 2rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3rem;
		padding: 0.8rem 1.5rem;
		border-radius: 999px;
		border: 1px solid currentColor;
		text-decoration: none;
		font-size: 0.82rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.button.primary,
	.button.dark {
		background: var(--color-ink);
		border-color: var(--color-ink);
		color: var(--color-white);
	}

	.button.ghost {
		color: var(--color-white);
	}

	.button.outline {
		color: var(--color-ink);
	}

	.intro,
	.featured,
	.amenities {
		padding: clamp(5rem, 10vw, 9rem) clamp(1.25rem, 6vw, 6rem);
	}

	.intro {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
		gap: clamp(2rem, 6vw, 7rem);
		align-items: start;
		background: var(--color-white);
	}

	.intro-details {
		padding-top: 1rem;
	}

	.text-link {
		display: inline-block;
		margin-top: 1rem;
		border-bottom: 1px solid currentColor;
		font-size: 0.86rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.text-image {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		align-items: stretch;
		min-height: 720px;
	}

	.panel {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: clamp(3rem, 7vw, 7rem);
	}

	.panel-sage {
		background: linear-gradient(var(--color-sage), rgba(255, 250, 244, 0.2));
	}

	.panel-linen {
		background: linear-gradient(var(--color-linen), rgba(255, 250, 244, 0.2));
	}

	.panel p {
		max-width: 570px;
	}

	.media-card {
		position: relative;
		min-height: 500px;
		overflow: hidden;
		background: var(--color-linen);
	}

	.media-card video {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.media-card.framed {
		margin: clamp(2rem, 5vw, 5rem);
		border: 1rem solid var(--color-white);
		box-shadow: 0 2rem 4rem rgba(47, 46, 51, 0.12);
	}

	.featured {
		background: var(--color-white);
	}

	.featured-header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(260px, 0.7fr);
		gap: clamp(2rem, 6vw, 6rem);
		align-items: end;
		margin-bottom: 3rem;
	}

	.featured-header .eyebrow {
		grid-column: 1 / -1;
		margin-bottom: 0;
	}

	.treatment-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1px;
		background: rgba(47, 46, 51, 0.16);
		border: 1px solid rgba(47, 46, 51, 0.16);
	}

	.treatment-card {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: 430px;
		padding: clamp(1.5rem, 3vw, 2.5rem);
		background: var(--color-cream);
	}

	.card-kicker {
		margin-bottom: 1.5rem;
		color: var(--color-olive);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.treatment-card a {
		align-self: flex-start;
		margin-top: 2rem;
		border-bottom: 1px solid currentColor;
		font-size: 0.82rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.experience {
		display: grid;
		grid-template-columns: minmax(260px, 0.8fr) minmax(0, 1.2fr);
		background: var(--color-ink);
		color: var(--color-white);
	}

	.experience-image {
		min-height: 620px;
		background-color: var(--color-linen);
		background-position: center;
		background-repeat: no-repeat;
		background-size: cover;
		filter: grayscale(0.15);
	}

	.experience-content {
		padding: clamp(4rem, 8vw, 8rem);
	}

	.experience h2,
	.experience h3 {
		color: var(--color-white);
	}

	.experience p {
		color: rgba(255, 250, 244, 0.72);
	}

	.experience-list {
		display: grid;
		gap: 2rem;
		margin-top: 3rem;
	}

	.experience-list article {
		padding-top: 2rem;
		border-top: 1px solid rgba(255, 250, 244, 0.22);
	}

	.amenities {
		background: var(--color-linen);
	}

	.amenities-header {
		max-width: 760px;
		margin-bottom: 3rem;
	}

	.amenities-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1px;
		background: rgba(47, 46, 51, 0.18);
		border: 1px solid rgba(47, 46, 51, 0.18);
	}

	.amenities-grid div {
		min-height: 220px;
		padding: clamp(1.5rem, 3vw, 2.5rem);
		background: var(--color-white);
	}

	.site-footer {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		padding: clamp(2rem, 4vw, 4rem) clamp(1.25rem, 6vw, 6rem);
		background: var(--color-white);
		border-top: 1px solid rgba(47, 46, 51, 0.12);
	}

	.site-footer div:last-child {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.5rem;
		text-align: right;
		color: var(--color-muted);
	}

	.footer-brand {
		margin-bottom: 0.2rem;
		color: var(--color-ink);
		font-family: var(--font-display);
		font-size: 2.2rem;
		line-height: 1;
	}

	@media (max-width: 980px) {
		.site-header {
			grid-template-columns: 1fr auto;
		}

		.main-nav {
			display: none;
		}

		.intro,
		.text-image,
		.featured-header,
		.experience,
		.site-footer {
			grid-template-columns: 1fr;
		}

		.text-image-left .media-card {
			order: 2;
		}

		.treatment-grid,
		.amenities-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.site-footer div:last-child {
			align-items: flex-start;
			text-align: left;
		}
	}

	@media (max-width: 640px) {
		.site-header {
			padding: 1rem;
		}

		.header-cta {
			padding: 0.7rem 1rem;
		}

		.hero {
			min-height: 88vh;
			padding-inline: 1rem;
		}

		h1 {
			font-size: clamp(4rem, 23vw, 7rem);
		}

		.treatment-grid,
		.amenities-grid {
			grid-template-columns: 1fr;
		}

		.treatment-card {
			min-height: 320px;
		}
	}
</style>
